<%
    const { Kvm } = require("/blueprint/js/lray138fp.min.js");
    const L = Kvm.of(locals);

    var globals = typeof globals !== "undefined" ? globals : {};

    var content = typeof content !== "undefined" ? content : "";
    
    var header = require("/blueprint/partials/header.ejs")({
        globals,
    });

    var footer = require("/blueprint/partials/footer.ejs")();
    
    // content = header + content + footer; 

    var head = typeof head !== "undefined" ? head : {};
    var head_meta = head.meta || {};
    var head_link = head.link || {};

    var utils = typeof utils !== "undefined" ? utils : {};
    
    var meta_title = typeof meta_title !== "undefined" ? meta_title : (head_meta.title || "Webpack + Bootstrap");

    var meta_description = typeof meta_description !== "undefined" ? meta_description : (head_meta.description || "");
    var meta_image = typeof meta_image !== "undefined" ? meta_image : (head_meta.image || "/img/blueprint/covers/outkast-is-everlasting.svg");
    var meta_url = typeof meta_url !== "undefined" ? meta_url : (head_meta.url || "");
    var meta_type = typeof meta_type !== "undefined" ? meta_type : (head_meta.type || "website");
    var meta_site_name = typeof meta_site_name !== "undefined" ? meta_site_name : (head_meta.site_name || "");
    var twitter_card = typeof twitter_card !== "undefined" ? twitter_card : (head_meta.twitter_card || "summary_large_image");
    var twitter_site = typeof twitter_site !== "undefined" ? twitter_site : (head_meta.twitter_site || "");
    var canonical_url = typeof canonical_url !== "undefined" ? canonical_url : (head_link.canonical || "");

    // a lot of the above is GPT garbage
    meta_title = L.tryPath('head.title').getOrElse('Blueprint');

    // Webpack dist theme (`public/site/`) — Carbon passes absolute `theme_css` / `theme_js` for CMS preview & live.
    var document_base_url = typeof document_base_url !== 'undefined' ? document_base_url : '/';
    var assets_root = typeof assets_root !== 'undefined' ? assets_root : '/site';
    var dev_q = typeof dev_assets !== 'undefined' && dev_assets ? '?carbonTheme=dev' : '';
    var theme_css_url = typeof theme_css !== 'undefined' ? theme_css : (assets_root + '/css/theme.css' + dev_q);
    var theme_js_url = typeof theme_js !== 'undefined' ? theme_js : (assets_root + '/js/theme.js' + dev_q);
%>
<!DOCTYPE html>
<html>
    <head>
        <base href="<%= document_base_url %>" />
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title><%- meta_title %></title>
        <link rel="stylesheet" href="<%= theme_css_url %>" />
        <script src="<%= theme_js_url %>" defer></script>
        <script src="https://cdn.jsdelivr.net/gh/gnat/surreal@main/surreal.js"></script>

        <% if (meta_description) { %>
            <meta name="description" content="<%- meta_description %>">
        <% } %>
        <% if (canonical_url) { %>
            <link rel="canonical" href="<%- canonical_url %>">
        <% } %>
        <% if (meta_url) { %>
            <meta property="og:url" content="<%- meta_url %>">
        <% } %>
        <% if (meta_type) { %>
            <meta property="og:type" content="<%- meta_type %>">
        <% } %>
        <% if (meta_title) { %>
            <meta property="og:title" content="<%- meta_title %>">
        <% } %>
        <% if (meta_description) { %>
            <meta property="og:description" content="<%- meta_description %>">
        <% } %>
        <% if (meta_image) { %>
            <meta property="og:image" content="<%- meta_image %>">
        <% } %>
        <% if (meta_site_name) { %>
            <meta property="og:site_name" content="<%- meta_site_name %>">
        <% } %>
        <% if (twitter_card) { %>
            <meta name="twitter:card" content="<%- twitter_card %>">
        <% } %>
        <% if (twitter_site) { %>
            <meta name="twitter:site" content="<%- twitter_site %>">
        <% } %>
        <% if (meta_title) { %>
            <meta name="twitter:title" content="<%- meta_title %>">
        <% } %>
        <% if (meta_description) { %>
            <meta name="twitter:description" content="<%- meta_description %>">
        <% } %>
        <% if (meta_image) { %>
            <meta name="twitter:image" content="<%- meta_image %>">
        <% } %>
        </head>
    <%
        var disableBpEdit = typeof carbon_disable_bp_edit !== 'undefined' && carbon_disable_bp_edit;
        var bodyClass = 'd-flex flex-column min-vh-100' + (disableBpEdit ? '' : ' bp-edit');
    %>
    <body class="<%= bodyClass %>"<% if (disableBpEdit) { %> data-carbon-disable-bp-edit="true"<% } %>>
        <%- content %>
        <script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js" integrity="sha384-GNFwBvfVxBkLMJpYMOABq3c+d3KnQxudP/mGPkzpZSTYykLBNsZEnG2D9G/X/+7D" crossorigin="anonymous" class="astro-vvvwv3sm"></script>
        <% if (typeof cms_edit_url !== 'undefined' && cms_edit_url) { %>
        <style>
            .carbon-cms-live-edit-fab {
                position: fixed;
                bottom: 1rem;
                left: 1rem;
                z-index: 1040;
                display: flex;
                align-items: center;
                justify-content: center;
                width: 2.5rem;
                height: 2.5rem;
                padding: 0.5rem;
                border: 0;
                border-radius: 50%;
                background: #fff;
                box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.15);
            }
            .carbon-cms-live-edit-fab:hover { opacity: 0.92; }
        </style>
        <a href="<%= cms_edit_url %>" class="carbon-cms-live-edit-fab" title="Edit in CMS" aria-label="Edit in CMS">
            <img src="/favicon.svg" width="24" height="24" alt="" aria-hidden="true" />
        </a>
        <% } %>
    </body>
</html>
