<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Github - Blueprint Docs</title>
    <script src="https://cdn.jsdelivr.net/gh/gnat/css-scope-inline@main/script.js"></script>
    </head>
    <body class="d-flex flex-column min-vh-100">
        <%
            var path = require('path');
            function vscodeFileHref(relFromWebpackRoot) {
                var abs = path.resolve(process.cwd(), relFromWebpackRoot).replace(/\\/g, '/');
                if (/^[a-zA-Z]:/.test(abs)) {
                    return 'vscode://file/' + abs;
                }
                return 'vscode://file//' + abs.replace(/^\/+/, '');
            }
            var carouselIndexEditHref = vscodeFileHref('src/blueprint/partials/components/carousel/index.ejs');

            var codeBlock = function(language, content) {
                return require("/blueprint/partials/components/code-block/index.ejs")({
                    content: content,
                    language: language || 'html'
                });
            };

            var carouselMarkup = require("/blueprint/partials/components/carousel/index.ejs")();

            // Build EJS open/close tokens with string concat so the compiler does not treat example source as real tags.
            var _eo = '<' + '%';
            var _ec = '%' + '>';
            var _ee = _eo + '=';
            var _en = _eo + '-';

            var carouselEjs = _eo + `
    var { Lst } = require("/blueprint/js/lray138fp.min.js");
    var defaultSlides = require("/blueprint/data/static/carousel.json").slides || [];
    var slides = typeof slides !== 'undefined' && slides ? slides : defaultSlides;
    var items = Lst.of(slides)
        .map(item => require("./item.ejs")(item))
        .join('');

    var carousel_id = "carouselExample";
    var ride = "carousel";
    var controls = require("./controls.ejs")({
        carousel_id
    });
    var indicator_items = typeof indicator_items !== 'undefined' && indicator_items
        ? indicator_items
        : slides.map((slide, index) => ({
            active: !!slide.active,
            index,
            label: slide.label || slide.alt || ("Slide " + (index + 1)),
        }));
    var indicators = require("./indicators.ejs")({
        carousel_id,
        items: indicator_items
    });
` + _ec + `
<div id="` + _ee + ` carousel_id ` + _ec + `" class="carousel slide carousel-fade" data-bs-interval="7000" data-bs-ride="` + _ee + ` ride ` + _ec + `">
    ` + _en + ` indicators ` + _ec + `
    <div class="carousel-inner">
        ` + _en + ` items ` + _ec + `
    </div>
    ` + _en + ` controls ` + _ec + `
</div>`;

            var carouselItemEjs = _eo + `
    // var src = '/img/carousel/1.jpg';
    var alt = '';
    
    var item_class = 'carousel-item';
    if(active) {
        item_class += ' active';
    }
` + _ec + `
<div class="` + _ee + ` item_class ` + _ec + `">
    <img class="d-block w-100" src="` + _ee + ` src ` + _ec + `" alt="` + _ee + ` alt ` + _ec + `">
</div>`;

            var carouselControlsEjs = `<button class="carousel-control-prev" type="button" data-bs-target="#` + _ee + ` carousel_id ` + _ec + `" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
<button class="carousel-control-next" type="button" data-bs-target="#` + _ee + ` carousel_id ` + _ec + `" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
</button>`;

            var carouselIndicatorsEjs = _eo + `
    var indicator_items = items || [];
    if (!indicator_items.length) {
        indicator_items = [
            {
                active: true,
                index: 0,
                label: "Slide 1",
            },
            {
                active: false,
                index: 1,
                label: "Slide 2",
            }
        ];
    }

    var buttons = indicator_items
        .map((item, idx) => require("./indicator-button.ejs")({
            active: typeof item.active !== 'undefined' ? item.active : idx === 0,
            index: typeof item.index !== 'undefined' ? item.index : idx,
            label: item.label,
            carousel_id,
        }))
        .join('');
` + _ec + `
<div class="carousel-indicators">
   ` + _en + ` buttons ` + _ec + `
</div>`;

            var carouselPhp = `<?php
# start use
# end use

return function($data = []) { 
	# start data processing
    extract($data);
    # end data processing
	return "<div id=\\"{$carousel_id}\\" class=\\"carousel slide carousel-fade\\" data-bs-interval=\\"7000\\" data-bs-ride=\\"{$ride}\\">{$indicators}<div class=\\"carousel-inner\\">{$items}</div>{$controls}</div><style>
/* default slow fade */
.carousel.carousel-fade .carousel-item {
  opacity: 0;
  transition: opacity 3s ease-in-out;
}

.carousel.carousel-fade .carousel-item.active,
.carousel.carousel-fade .carousel-item-next.carousel-item-start,
.carousel.carousel-fade .carousel-item-prev.carousel-item-end {
  opacity: 1;
}

.carousel.carousel-fade .active.carousel-item-start,
.carousel.carousel-fade .active.carousel-item-end {
  opacity: 0;
}

/* fast fade when user clicks */
.carousel.carousel-fade.fast-fade .carousel-item {
  transition: opacity 0.75s ease-in-out;
}

</style><script>
document.querySelectorAll(\\".carousel\\").forEach(carousel => {

const setFast = () => carousel.classList.add(\\"fast-fade\\");
const setSlow = () => carousel.classList.remove(\\"fast-fade\\");

// when user clicks next/prev
carousel.querySelectorAll(\\"[data-bs-slide]\\").forEach(btn => {
  btn.addEventListener(\\"pointerdown\\", () => {
    console.log(\\"fast fade\\");
    setFast();
  });
});

// after slide completes, revert to slow
carousel.addEventListener(\\"slid.bs.carousel\\", () => {
  setSlow();
});

});


</script>";
};

# src: webpack/src/blueprint/partials/components/carousel/index.ejs`;
        %>
        <!-- Header -->
        <div class="container-fluid">
            <%- require("/blueprint/partials/header.ejs")({
                base_url: base_url,
                fluid: true
            }) %>
        </div>
        
        <!-- Docs Content -->
        <section>
            <div class="container-fluid">
                <div class="row">
                    
                    <!-- Left Sidebar Navigation -->
          <%- require("/blueprint/partials/docs/sidebar.ejs")({ base_url, current_path }) %>
                    
                    <!-- Main Content -->
                    <div class="col-12 col-lg-6 col-xl-8 py-7 py-lg-9 px-lg-7" id="doc-content">
                        <!-- Page Title -->
                        <h1 class="mb-2">Carousel</h1>
                        <p class="fs-lg text-muted mb-3">Showcase a set of images or content in a rotating slideshow. See full documentation
                             <a href="https://getbootstrap.com/docs/5.3/components/carousel/" target="_blank">https://getbootstrap.com/docs/5.3/components/carousel/</a>.</p>

                        <%- require("/blueprint/partials/docs/component-props-table.ejs")({
                            title: 'Carousel partial (index.ejs)',
                            edit: carouselIndexEditHref,
                            intro: 'Include with no arguments. Slides and options are set inside the partial file.',
                            properties: [
                                { name: 'carousel_id', type: 'string', description: 'Root element id; must match data-bs-target on controls and indicators.', required: false, default: 'carouselExample' },
                                { name: 'ride', type: 'string', description: 'Bootstrap data-bs-ride value for auto-cycling.', required: false, default: 'carousel' },
                                { name: 'items', type: 'object[]', description: 'Slide objects passed into item.ejs (see below). Exactly one should use active: true.', required: true },
                            ],
                        }) %>

                        <%- require("/blueprint/partials/docs/component-props-table.ejs")({
                            title: 'Slide item (item.ejs)',
                            intro: 'Each slide in the items array is rendered through this partial.',
                            properties: [
                                { name: 'active', type: 'boolean', description: 'Whether this slide is visible on first paint.', required: true },
                                { name: 'src', type: 'string', description: 'Image URL.', required: true },
                                { name: 'alt', type: 'string', description: 'Image alt text. Optional; the partial defaults to an empty string if unset.', required: false },
                            ],
                        }) %>

                        <%- require("/blueprint/partials/docs/component-props-table.ejs")({
                            title: 'Controls & indicators (controls.ejs, indicators.ejs)',
                            intro: 'Both partials require the same carousel id as the root element.',
                            properties: [
                                { name: 'carousel_id', type: 'string', description: 'Matches the root carousel element id (hash is added in markup).', required: true },
                            ],
                        }) %>

                        <%- require("/blueprint/partials/docs/component-props-table.ejs")({
                            title: 'Indicator button (indicator-button.ejs)',
                            intro: 'Composed inside indicators.ejs for each slide.',
                            properties: [
                                { name: 'active', type: 'boolean', description: 'Adds the active class and aria-current when true.', required: true },
                                { name: 'index', type: 'integer', description: 'Zero-based slide index (data-bs-slide-to).', required: true },
                                { name: 'carousel_id', type: 'string', description: 'Target carousel id for data-bs-target.', required: true },
                            ],
                        }) %>
                        
                        <h3 class="mb-2">Standard</h3>
                        <p>A standard carousel using the Blueprint component partial.</p>

                        <%- require("/blueprint/partials/components/tabs/index.ejs")({
                            items: [
                                {
                                    id: 'carousel-preview',
                                    text: 'Preview',
                                    selected: true,
                                    content: carouselMarkup
                                },
                                {
                                    id: 'carousel-html',
                                    text: 'Source HTML',
                                    content: codeBlock('html', carouselMarkup)
                                }
                            ]
                        }) %>

                        <h3 class="mt-4 mb-2">Implementation breakdown</h3>
                        <p>Here is how the carousel is split into EJS partials and compiled into PHP.</p>

                        <%- require("/blueprint/partials/components/tabs/index.ejs")({
                            items: [
                                {
                                    id: 'carousel-ejs-index',
                                    text: 'Entry EJS (index.ejs)',
                                    selected: true,
                                    content: codeBlock('ejs', carouselEjs)
                                },
                                {
                                    id: 'carousel-ejs-item',
                                    text: 'EJS: item.ejs',
                                    content: codeBlock('ejs', carouselItemEjs)
                                },
                                {
                                    id: 'carousel-ejs-controls',
                                    text: 'EJS: controls.ejs',
                                    content: codeBlock('ejs', carouselControlsEjs)
                                },
                                {
                                    id: 'carousel-ejs-indicators',
                                    text: 'EJS: indicators.ejs',
                                    content: codeBlock('ejs', carouselIndicatorsEjs)
                                },
                                {
                                    id: 'carousel-php-compiled',
                                    text: 'PHP: compiled',
                                    content: codeBlock('php', carouselPhp)
                                }
                            ]
                        }) %>

                        <hr class="my-4"/>
                        
                        <%- require("/blueprint/partials/components/nav-pager/index.ejs")({
                            next: "<a href='/tutorials/webpack-html/project-setup/index.html' class='nav-pager-item'><div class='text-uppercase small text-muted'>Next</div><p class='mb-0'>Welcome (to the Jungle)</p></a>"
                        }) %>
                    </div>
                    
                    <!-- Right "Jump to" Sidebar -->
                    <%- require("/blueprint/partials/docs/jump-to.ejs")() %>
                    
                </div>
            </div>
        </section>
        
        <!-- Footer -->
        <div class="container mt-auto">
            <%- require("/blueprint/partials/footer.ejs")() %>
        </div>
        
        <%- require("/blueprint/partials/svg-icons.ejs")() %>
    </body>
</html>
