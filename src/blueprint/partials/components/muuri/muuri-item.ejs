<%
    /**
     * Single Muuri tile + BigPicture trigger.
     * Locals: item ({ id, src, alt, caption?, fullSrc?, permalink?, pageHref?, pageLinkLabel? }), bpGalleryOpts.
     * permalink/pageHref: optional URL; desktop lightbox icon in vendor/bigpicture.js.
     */
    var item = typeof item !== "undefined" ? item : {};
    var bpGalleryOpts = typeof bpGalleryOpts !== "undefined" ? bpGalleryOpts : "{}";
    var thumbSrc = item.src || "";
    var fullSrc = item.fullSrc || item.src || "";
    var caption = item.caption != null && item.caption !== "" ? String(item.caption) : "";
    var itemId = item.id != null ? item.id : "";
    var altText = item.alt != null ? String(item.alt) : "";
    var permalink = item.permalink != null && String(item.permalink).trim() !== "" ? String(item.permalink) : "";
    var pageHref =
        permalink ||
        (item.pageHref != null && String(item.pageHref).trim() !== "" ? String(item.pageHref) : "");
    var pageLinkLabel =
        item.pageLinkLabel != null && String(item.pageLinkLabel).trim() !== ""
            ? String(item.pageLinkLabel)
            : "Open full page";

    var captionDataAttr = caption
        ? ' data-caption="' + caption.replace(/"/g, "&quot;") + '"'
        : "";
    var figcaptionHtml = caption
        ? '<figcaption class="small text-secondary mt-1 px-1">' + caption + "</figcaption>"
        : "";
    var pageDataAttrs = pageHref
        ? " data-page-href=\"" +
          pageHref.replace(/"/g, "&quot;") +
          "\" data-page-link-label=\"" +
          pageLinkLabel.replace(/"/g, "&quot;") +
          "\""
        : "";

    captionDataAttr = "";
%>
<div class="muuri-item" data-item-id="<%= itemId %>">
    <div class="muuri-item-content">
        <figure class="position-relative mb-0 muuri-item-figure">
            <a
                href="<%= fullSrc %>"
                class="muuri-item-lightbox d-block text-decoration-none"
                data-bp="<%= fullSrc %>"
                data-bigpicture='<%- bpGalleryOpts %>' <%- pageDataAttrs %> <%- captionDataAttr %>
            >
                <img
                    class="muuri-item-img w-100 rounded"
                    src="<%- thumbSrc %>"
                    alt="<%- altText %>"
                    loading="lazy"
                    decoding="async"
                />
            </a>
            <!-- <%- figcaptionHtml %> -->
        </figure>
    </div>
</div>
