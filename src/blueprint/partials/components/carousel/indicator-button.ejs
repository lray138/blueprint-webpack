<% 
    var class_name = active ? "active" : "";
    var aria_current = active ? "true" : "false";
    var label_text = typeof label !== 'undefined' && label ? label : ("Slide " + (index + 1));
%>
<button type="button" data-bs-target="#<%= carousel_id %>" data-bs-slide-to="<%= index %>" class="<%= class_name %>" aria-current="<%= aria_current %>" aria-label="<%= label_text %>"></button>
