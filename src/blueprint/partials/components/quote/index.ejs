<% 
    var text = typeof text !== "undefined" ? text : "Lorum ipsum dolor sit amet";
    var source = typeof source !== "undefined" ? source : "John Doe";
%>
<blockquote class="blockquote text-center">
    <p class="mb-4 mb-md-4 quote-body"><%- text %></p>

    <div class="mb-0 blockquote-footer">
        <span class="quote-source h6 text-uppercase mb-2 mb-0"><%- source %></span>
    </div>
</blockquote>
